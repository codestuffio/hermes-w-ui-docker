# .env — copy to .env.local and fill in your values.
# In Coolify, set these in the Environment Variables panel instead.

# --- LLM Provider Keys (set at least one) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: messaging gateway ---
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# --- Optional overrides ---
HERMES_DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4-5
WEBUI_PORT=8787
