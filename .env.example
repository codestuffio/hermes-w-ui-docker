# Hermes Docker Environment Variables
# Copy this file to .env and fill in your values
# In Coolify, set these in the Environment Variables panel instead.
# DO NOT commit .env to version control.

# =============================================================================
# PROVIDER API KEYS
# Set at least one provider key. OpenRouter is recommended (200+ models).
# =============================================================================

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# MESSAGING GATEWAY TOKENS
# Optional: enable messaging platforms to talk to Hermes
# =============================================================================

TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Default model when no model is specified (format: provider/model-name)
# Examples:
#   - openrouter/anthropic/claude-sonnet-4-5
#   - openai/gpt-4o
#   - anthropic/claude-3-5-sonnet
HERMES_DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4-5

# =============================================================================
# WEBUI CONFIGURATION
# =============================================================================

# Port for the web UI (default: 8787)
WEBUI_PORT=8787

# Password protection for web UI (optional, recommended for remote access)
# Uncomment and set a strong password:
# HERMES_WEBUI_PASSWORD=your-secret-password